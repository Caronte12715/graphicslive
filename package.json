{
  "name": "orbit",
  "version": "1.1.0",
  "description": "Motor de gráficos para transmisiones en vivo — alternativa a H2R Graphics",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder --win --x64 --ia32"
  },
  "keywords": [
    "graphics",
    "broadcast",
    "obs",
    "lower-thirds",
    "live"
  ],
  "author": "David Guevara (Caronte12715)",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "localtunnel": "^2.0.2",
    "qrcode": "^1.5.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@fiahfy/ico-convert": "^0.0.12",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.orbit.app",
    "productName": "Orbit",
    "icon": "assets/icons/icon.ico",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "installerSidebar": "assets/icons/installerSidebar.png",
      "installerHeader": "assets/icons/installerHeader.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "renderer/**/*",
      "output/**/*",
      "templates/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "templates",
        "to": "templates"
      }
    ]
  }
}
